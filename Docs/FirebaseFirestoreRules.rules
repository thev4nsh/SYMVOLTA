rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if owns(uid)
        && request.resource.data.uid == uid
        && request.resource.data.globalScore is number
        && request.resource.data.globalScore >= 0
        && request.resource.data.globalScore <= 100;
    }

    match /usernames/{username} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }

    match /leaderboards/{boardId}/scores/{uid} {
      allow read: if signedIn();
      allow create, update: if owns(uid)
        && request.resource.data.uid == uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100
        && request.resource.data.hash is string;
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
